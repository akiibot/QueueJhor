# Copy to .env and fill in only if you want the Gemini AI fallback.
# The service runs fully without any of these (deterministic rules mode).
# Gemini is ONLY called when the rules engine cannot categorize a ticket.

# Enable the AI fallback for ambiguous tickets.
USE_LLM=false

# Gemini API key (only read when USE_LLM=true). Never commit a real key.
GEMINI_API_KEY=

# Gemini model to use. gemini-2.0-flash is fast and has a free tier.
GEMINI_MODEL=gemini-2.0-flash

# Hard timeout (seconds) for the Gemini call before falling back to rules.
LLM_TIMEOUT=10

# Port the service binds to.
PORT=8000
