# Copy to .env and fill in only if you want the optional LLM polish layer.
# The service runs fully without any of these (deterministic rules mode).

# Enable the optional LLM rewriting of agent_summary / customer_reply.
USE_LLM=false

# Anthropic API key (only read when USE_LLM=true). Never commit a real key.
ANTHROPIC_API_KEY=

# Model used for polish. Haiku is fast and cheap; well within the 30s timeout.
LLM_MODEL=claude-haiku-4-5-20251001

# Hard timeout (seconds) for the polish call before falling back to templates.
LLM_TIMEOUT=8

# Port the service binds to.
PORT=8000
